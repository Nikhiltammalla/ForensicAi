<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0"
            prefWidth="600.0"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="forensicai.v2.Upload_sketchController">

    <children>

        <Text layoutX="140.0"
              layoutY="100.0"
              text="UPLOAD SKETCH SYSTEM">

            <font>
                <Font size="28.0"/>
            </font>

        </Text>

        <Button layoutX="180.0"
                layoutY="180.0"
                prefHeight="50.0"
                prefWidth="240.0"
                text="OPEN FACE RECOGNITION"
                onAction="#openFaceRecognition"/>

        <Button layoutX="180.0"
                layoutY="250.0"
                prefHeight="50.0"
                prefWidth="240.0"
                text="BACK"
                onAction="#onBack"/>

    </children>

</AnchorPane>